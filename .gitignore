# ============================================================
# BINIFY .gitignore
# ============================================================

# Environment & secrets
.env
*.env

# Database files
backend/instance/
*.db
*.sqlite

# Uploaded images (user data)
backend/uploads/

# User corrections log
backend/corrections.json

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Dataset (large, keep local)
DATASET/

# macOS
.DS_Store

# Virtual environments
venv/
env/
.venv/

# IDEs
.vscode/
.idea/

# Logs
*.log
